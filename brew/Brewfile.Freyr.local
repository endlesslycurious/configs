# Manifest file for homebrew using the brew file addon.
#   Generate	brew bundle dump
#   Check		brew bundle check
#   Update		brew bundle install
#   Clean		brew bundle cleanup
# More output with --verbose option

# Third party recipes, requires explicit 'trust' to install
tap "jundot/omlx", "https://github.com/jundot/omlx", trusted: true

# Packages
brew "bash-completion"          # CLI auto complete
brew "bat"                      # Cat with syntax highlighting and Git integration
brew "btop"                     # Terminal system monitor
brew "cloc"                     # Count lines of code
brew "dust"                     # du (disk usage) port in Rust
brew "fzf"                      # Fuzzy file finder
brew "fd"                       # find alternative
brew "fzf"                      # Fuzzy file finder
brew "git"                      # Git source control
brew "hf"                       # Hugging Face CLI
brew "neovim"                   # Modern VIM
brew "oh-my-posh"               # prompt theme engine
brew "omlx"                     # MLX native LLM server
brew "python"                   # Python programming language
brew "ripgrep"                  # Faster grep
brew "stylua"                   # Lua formatter
brew "tealdeer"                 # Better man pages
brew "tmux"                     # Better terminal
brew "tree"                     # Directory lister
brew "tree-sitter"              # Text parsing library
brew "tree-sitter-cli"          # Text parsing toolchain
brew "uv"                       # Modern python package management
brew "watch"                    # Watch command
brew "wget"                     # Internet file retriever
brew "zig"                      # Low level programming language, C toolchain replacement

# Applications
cask "appcleaner"                    # Application file cleanup
cask "font-hack-nerd-font"           # Programming fonts
cask "iterm2"                        # better terminal interface
cask "font-jetbrains-mono-nerd-font" # Nerd font
cask "neovide-app"                   # Window mode for NeoVim
